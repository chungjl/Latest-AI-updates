<view class="page">
  <view class="nav">
    <text class="nav-title">趋势榜</text>
    <button class="nav-more">•••</button>
  </view>

  <view class="hero">
    <text class="hero-title">24小时热度变化</text>
    <text class="hero-subtitle">发现正在升温的 AI 主题、公司和开源项目</text>
  </view>

  <view wx:for="{{trends}}" wx:key="name" class="trend-card card">
    <view class="trend-row">
      <text>{{item.name}}</text>
      <text class="{{item.delta < 0 ? 'negative' : 'positive'}}">{{item.delta > 0 ? '+' : ''}}{{item.delta}}%</text>
    </view>
    <view class="bar"><view class="{{item.delta < 0 ? 'red' : item.color}}" style="width: {{item.width}}%;"></view></view>
  </view>
</view>
