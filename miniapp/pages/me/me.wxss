.profile {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-top: 56rpx;
  margin-bottom: 52rpx;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #6366f1, #06b6d4);
}

.profile-name {
  display: block;
  color: #101828;
  font-size: 40rpx;
  font-weight: 950;
}

.profile-meta {
  display: block;
  margin-top: 12rpx;
  color: #667085;
  font-size: 26rpx;
}

.menu-card {
  min-height: 114rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding: 26rpx 34rpx;
}

.menu-card view text:first-child {
  display: block;
  color: #101828;
  font-size: 30rpx;
  font-weight: 950;
}

.menu-card view text:last-child {
  display: block;
  margin-top: 8rpx;
  color: #667085;
  font-size: 25rpx;
}

.menu-card > text {
  color: #98a2b3;
  font-size: 48rpx;
  font-weight: 900;
}
