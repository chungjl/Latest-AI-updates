.event-hero {
  display: block;
  margin-top: 34rpx;
  padding: 34rpx;
}

.event-title {
  display: block;
  color: #101828;
  font-size: 42rpx;
  line-height: 1.24;
  font-weight: 950;
}

.event-meta {
  display: block;
  margin-top: 18rpx;
  color: #6366f1;
  font-size: 25rpx;
  font-weight: 850;
}

.event-summary {
  display: block;
  margin-top: 20rpx;
  color: #667085;
  font-size: 27rpx;
  line-height: 1.55;
}

.article-card {
  display: block;
  margin-bottom: 24rpx;
  padding: 30rpx;
}

.article-title {
  display: block;
  margin-top: 22rpx;
  color: #101828;
  font-size: 32rpx;
  line-height: 1.34;
  font-weight: 950;
}

.article-summary {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-top: 18rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.52;
}
