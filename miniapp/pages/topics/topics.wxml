<view class="page">
  <view class="nav">
    <text class="nav-title">专题追踪</text>
    <button class="nav-more">•••</button>
  </view>

  <view class="hero">
    <text class="hero-title">我的追踪专题</text>
    <text class="hero-subtitle">把分散资讯归并到长期观察主题里</text>
  </view>

  <view wx:for="{{topics}}" wx:key="id" class="topic-card card" data-id="{{item.id}}" bindtap="openTopic">
    <view class="topic-icon"></view>
    <view>
      <text class="topic-name">{{item.name}}</text>
      <text class="topic-meta">{{item.keywordsText}}</text>
    </view>
    <text class="topic-status">{{item.enabled ? '升温' : '暂停'}}</text>
  </view>

  <view class="create-card card">
    <text class="create-title">新建追踪专题</text>
    <input placeholder="专题名称，例如 AI Agent" value="{{topicName}}" bindinput="onNameInput" />
    <input placeholder="关键词，用逗号分隔" value="{{topicKeywords}}" bindinput="onKeywordsInput" />
    <button class="primary-action" bindtap="createTopic">+ 新建追踪专题</button>
  </view>
</view>
