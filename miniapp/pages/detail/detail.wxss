.detail-head {
  margin-top: 38rpx;
}

.detail-head > view {
  display: flex;
  gap: 18rpx;
}

.detail-title {
  display: block;
  margin-top: 34rpx;
  color: #101828;
  font-size: 46rpx;
  line-height: 1.22;
  font-weight: 950;
}

.detail-meta {
  display: block;
  margin-top: 28rpx;
  color: #667085;
  font-size: 26rpx;
}

.summary {
  margin-top: 42rpx;
  padding: 36rpx;
}

.summary-title {
  display: block;
  color: #101828;
  font-size: 32rpx;
  font-weight: 950;
}

.summary-text {
  display: block;
  margin-top: 24rpx;
  color: #344054;
  font-size: 29rpx;
  line-height: 1.65;
}

.summary-note {
  display: block;
  margin-top: 18rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.55;
}

.signal {
  margin-bottom: 24rpx;
  padding: 26rpx 30rpx;
  color: #344054;
  font-size: 28rpx;
}

.primary-action,
.secondary-action {
  height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 28rpx;
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 900;
}

.primary-action {
  color: #ffffff;
  background: #101828;
}

.secondary-action {
  color: #101828;
  background: rgba(255, 255, 255, 0.78);
}
