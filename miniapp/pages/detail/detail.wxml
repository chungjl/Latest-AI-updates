<view class="page detail-page">
  <view class="nav">
    <button class="nav-back" bindtap="goBack">‹</button>
    <text class="nav-title">资讯详情</text>
    <button class="nav-more">•••</button>
  </view>

  <view class="detail-head">
    <view>
      <text class="pill">{{item.source || '未知来源'}}</text>
      <text class="pill pill-green">影响力 {{score}}</text>
    </view>
    <text class="detail-title">{{item.title}}</text>
    <text class="detail-meta">{{item.category}} · {{item.source_type}}</text>
  </view>

  <view class="summary card">
    <text class="summary-title">AI 摘要</text>
    <text class="summary-text">{{item.summary || '暂无摘要，建议复制原文链接后在浏览器查看。'}}</text>
  </view>

  <text class="section-title">关键信号</text>
  <view class="signal card">• {{item.category || '综合资讯'}} 方向出现新动态</view>
  <view class="signal card">• 来源为 {{item.source || '未知来源'}}，建议结合原文判断</view>
  <view class="signal card">• 适合加入专题追踪或收藏后续观察</view>

  <button class="primary-action" bindtap="toggleBookmark">{{bookmarked ? '取消收藏' : '收藏并加入专题追踪'}}</button>
  <button class="secondary-action" bindtap="copyLink">复制原文链接</button>
  <button class="secondary-action" bindtap="shareText">复制分享文案</button>
</view>
