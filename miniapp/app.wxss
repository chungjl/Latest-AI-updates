page {
  min-height: 100%;
  color: #101828;
  background: #f7f8fc;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
input,
button {
  box-sizing: border-box;
}

button {
  padding: 0;
  line-height: normal;
  background: transparent;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 56rpx;
  background:
    radial-gradient(circle at 18% 0%, rgba(99, 102, 241, 0.12) 0 150rpx, transparent 330rpx),
    radial-gradient(circle at 44% 0%, rgba(6, 182, 212, 0.08) 0 180rpx, transparent 360rpx),
    #f7f8fc;
}

.nav {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 8rpx;
}

.nav-title {
  font-size: 40rpx;
  line-height: 1.15;
  font-weight: 900;
  letter-spacing: 0;
}

.nav-back {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #101828;
  font-size: 42rpx;
  font-weight: 900;
}

.nav-more {
  min-width: 82rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(16, 24, 40, 0.08);
  border-radius: 999rpx;
  color: #101828;
  background: rgba(255, 255, 255, 0.72);
  font-size: 30rpx;
  font-weight: 900;
}

.hero {
  margin-top: 42rpx;
}

.hero-title {
  display: block;
  font-size: 56rpx;
  line-height: 1.16;
  font-weight: 950;
  letter-spacing: 0;
}

.hero-subtitle {
  display: block;
  margin-top: 18rpx;
  color: #667085;
  font-size: 27rpx;
  line-height: 1.55;
}

.card {
  border: 2rpx solid rgba(16, 24, 40, 0.08);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 24rpx 64rpx rgba(15, 23, 42, 0.08);
}

.pill {
  min-height: 44rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #344054;
  background: #f2f4f7;
  font-size: 24rpx;
  font-weight: 800;
}

.pill-green {
  color: #047857;
  background: rgba(16, 185, 129, 0.12);
}

.section-title {
  display: block;
  margin: 44rpx 0 20rpx;
  font-size: 40rpx;
  font-weight: 950;
  line-height: 1.2;
}

.empty {
  padding: 56rpx 24rpx;
  color: #667085;
  text-align: center;
  font-size: 27rpx;
}
